<Window x:Class="smtc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" Height="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Border CornerRadius="15" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部栏：应用名 + 序号 + 按钮 -->
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0 0 0 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtAppName"
                               Text="无播放信息"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#222"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtIndex"
                               Text="0/0"
                               FontSize="12"
                               Foreground="#888"
                               Margin="8 0 0 0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content=">"
                            Width="30" Height="30"
                            Click="NextButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="16"
                            Foreground="#555"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#4285F4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="×"
                            Width="30" Height="30"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="18"
                            Foreground="#555"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FF5555"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ✅ 核心修复：固定高度100 + 三行均分占满 + 大字体填充 -->
            <Grid Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0" Height="100">
                <!-- 三行均分高度，占满整个100容器 -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 歌曲标题：放大字体 + 行内垂直居中 -->
                <TextBlock x:Name="txtTitle" 
                           Grid.Row="0"
                           Text="Title"
                           FontSize="24" FontWeight="Bold" Foreground="#111"
                           TextWrapping="NoWrap" 
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>

                <!-- 歌手：放大字体 + 行内垂直居中 -->
                <TextBlock x:Name="txtArtist" 
                           Grid.Row="1"
                           Text="Artist"
                           FontSize="18" Foreground="#666"
                           TextWrapping="NoWrap" 
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>

                <!-- 播放状态：放大字体 + 行内垂直居中 -->
                <TextBlock x:Name="txtPlayState" 
                           Grid.Row="2"
                           Text="状态"
                           FontSize="16" Foreground="#888"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- 右侧封面：固定100x100，与左侧高度完全一致 -->
            <Border Grid.Row="1" Grid.Column="1" 
                    CornerRadius="10" 
                    ClipToBounds="True" 
                    VerticalAlignment="Center"
                    Height="100">
                <Image x:Name="imgCover" Stretch="UniformToFill" Width="100" Height="100"/>
            </Border>

            <!-- 进度条区域 -->
            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0 10 0 0">
                <Border Height="10" CornerRadius="5" Background="#CCCCCC" ClipToBounds="True">
                    <ProgressBar x:Name="progressBar" 
                                 Background="Transparent" 
                                 Foreground="#4285F4">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border CornerRadius="3" Background="{TemplateBinding Background}">
                                                <Grid x:Name="PART_Track">
                                                    <Border x:Name="PART_Indicator" 
                                                            CornerRadius="3" 
                                                            Background="{TemplateBinding Foreground}" 
                                                            HorizontalAlignment="Left"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </Border>
                <Grid Margin="0 4 0 0">
                    <TextBlock x:Name="txtCurrentTime" FontSize="12" Foreground="#666" Text="00:00" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="txtTotalTime" FontSize="12" Foreground="#666" Text="00:00" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
